---
import Layout from "@layouts/Layout.astro";
import { RESUME } from "@data/resume";
import publications from "@data/publications.json";

const { name, location, summary, contact, work, education, skills } = RESUME;

const contactItems = [
  { label: contact.email, href: `mailto:${contact.email}` },
  { label: contact.tel, href: `tel:${contact.tel.replace(/[^0-9+]/g, "")}` },
  { label: "linkedin", href: contact.linkedin, external: true },
  { label: "github", href: contact.github, external: true },
  { label: "elijahlewis.dev", href: contact.website, external: true },
];
---

<Layout
  title="CV — Elijah Lewis"
  description="Curriculum vitae of Elijah Lewis."
>
  <article
    class="mx-auto w-full max-w-[820px] px-6 py-14 md:px-10 print:max-w-none print:px-0 print:py-0"
  >
    {/* LETTERHEAD */}
    <header class="border-b-4 border-line pb-5">
      <h1
        class="font-poster text-5xl leading-none uppercase md:text-6xl print:text-4xl"
      >
        {name}
      </h1>
      <p
        class="mt-3 flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs tracking-wide text-muted"
      >
        <span>{location}</span>
        {
          contactItems.map((c) => (
            <>
              <span class="text-faint">·</span>
              <a
                href={c.href}
                target={c.external ? "_blank" : undefined}
                rel={c.external ? "noopener noreferrer" : undefined}
                class="hover:text-indigo"
              >
                {c.label}
              </a>
            </>
          ))
        }
      </p>
    </header>

    {/* SUMMARY */}
    <p class="mt-6 max-w-[68ch] text-base leading-relaxed text-muted">
      {summary}
    </p>

    {/* EXPERIENCE */}
    <section class="mt-10 print:mt-6">
      <h2
        class="mb-5 border-b-2 border-line pb-2 font-poster text-xl uppercase tracking-tight"
      >
        Experience
      </h2>
      <div class="space-y-7 print:space-y-4">
        {
          work.map((job) => (
            <article class="break-inside-avoid">
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <h3 class="font-sans text-base font-extrabold">
                  {job.link ? (
                    <a
                      href={job.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-indigo"
                    >
                      {job.company}
                    </a>
                  ) : (
                    job.company
                  )}
                  {job.context && (
                    <span class="ml-1 font-normal text-faint">
                      — {job.context}
                    </span>
                  )}
                </h3>
                <span class="font-mono text-xs whitespace-nowrap text-faint">
                  {job.start} – {job.end}
                </span>
              </div>
              <div class="mt-0.5 flex flex-wrap items-baseline justify-between gap-x-3">
                <p class="font-mono text-xs uppercase tracking-wide text-indigo">
                  {job.title}
                </p>
                <span class="font-mono text-xs text-faint">{job.location}</span>
              </div>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-relaxed text-muted marker:text-faint">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
              {job.skills && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {job.skills.map((s) => (
                    <span class="border border-line px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted">
                      {s}
                    </span>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </div>
    </section>

    {/* EDUCATION */}
    <section class="mt-10 print:mt-6">
      <h2
        class="mb-5 border-b-2 border-line pb-2 font-poster text-xl uppercase tracking-tight"
      >
        Education
      </h2>
      {
        education.map((ed) => (
          <div class="flex flex-wrap items-baseline justify-between gap-x-3">
            <div>
              <h3 class="font-sans text-base font-extrabold">{ed.school}</h3>
              <p class="text-sm text-muted">{ed.degree}</p>
            </div>
            <span class="font-mono text-xs whitespace-nowrap text-faint">
              {ed.start} – {ed.end}
            </span>
          </div>
        ))
      }
    </section>

    {/* SKILLS */}
    <section class="mt-10 print:mt-6">
      <h2
        class="mb-5 border-b-2 border-line pb-2 font-poster text-xl uppercase tracking-tight"
      >
        Skills
      </h2>
      <dl class="space-y-3">
        {
          Object.entries(skills).map(([group, items]) => (
            <div class="grid grid-cols-[9rem_1fr] gap-x-3 print:grid-cols-[8rem_1fr]">
              <dt class="font-mono text-xs uppercase tracking-wide text-indigo">
                {group}
              </dt>
              <dd class="text-sm text-muted">{items.join(", ")}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    {/* PUBLICATIONS */}
    <section class="mt-10 print:mt-6">
      <h2
        class="mb-5 border-b-2 border-line pb-2 font-poster text-xl uppercase tracking-tight"
      >
        Publications
      </h2>
      <ul class="space-y-3">
        {
          publications.map((pub) => (
            <li class="text-sm leading-relaxed text-muted">
              <span class="font-semibold text-ink">{pub.authors}</span> (
              {pub.year}). {pub.title}.{" "}
              <span class="text-marigold">{pub.journal}</span>.{" "}
              <a
                href={pub.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-indigo underline underline-offset-2 print:no-underline"
              >
                {pub.url}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</Layout>
