---
interface Props {
  title: string;
  caption?: string;
  as?: "h1" | "h2"; // h1 when this header IS the page title (standalone list pages)
}

const { title, caption, as: Heading = "h2" } = Astro.props;
---

<div
  class="mb-8 flex items-end justify-between gap-4 border-b-4 border-line pb-4"
>
  <Heading class="font-poster text-3xl leading-none uppercase md:text-4xl">
    {title}
  </Heading>
  {
    caption && (
      <span class="font-mono text-xs tracking-widest whitespace-nowrap text-faint uppercase">
        {caption}
      </span>
    )
  }
</div>
