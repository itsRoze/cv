---
import Layout from "@layouts/Layout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import publications from "@data/publications.json";
---

<Layout
  title="Publications — Elijah Lewis"
  description="Peer-reviewed research co-authored by Elijah Lewis."
>
  <section class="mx-auto w-full max-w-[1100px] px-6 py-14 md:px-10">
    <SectionHeader
      as="h1"
      title="Publications"
      caption={`[ ${publications.length} works ]`}
    />
    {
      publications.map((pub) => (
        <a
          href={pub.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group grid grid-cols-[1fr_auto] items-baseline gap-5 border-b border-line py-5 transition-[padding] hover:pl-3"
        >
          <div>
            <div class="font-sans text-lg font-extrabold uppercase transition-colors group-hover:text-indigo md:text-xl">
              {pub.title}
            </div>
            <p class="mt-1 font-mono text-xs tracking-wide text-marigold uppercase">
              {pub.authors} · {pub.journal} · {pub.year}
            </p>
            <p class="mt-2 max-w-[60ch] text-sm text-muted">
              {pub.description}
            </p>
          </div>
          <span class="text-right font-mono text-xs whitespace-nowrap text-faint">
            ↗
          </span>
        </a>
      ))
    }
  </section>
</Layout>
