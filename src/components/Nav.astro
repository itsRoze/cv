---
const links = [
  { name: "Home", href: "/" },
  { name: "Writing", href: "/posts" },
  { name: "Projects", href: "/projects" },
  { name: "Publications", href: "/publications" },
  { name: "CV", href: "/cv" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<nav class="border-b-[3px] border-line print:hidden">
  <div
    class="mx-auto flex w-full max-w-[1100px] flex-wrap items-center justify-between gap-x-6 gap-y-3 px-6 pt-6 pb-5 md:px-10"
  >
    <a
      href="/"
      class="font-poster text-2xl leading-none uppercase tracking-tight"
      aria-label="Elijah Lewis — home"
    >
      Elijah Lewis
    </a>

    <ul
      class="flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-xs tracking-wider uppercase"
    >
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class:list={[
                "border-b-2 pb-0.5 transition-colors hover:text-indigo",
                isActive(link.href)
                  ? "border-indigo text-indigo"
                  : "border-transparent text-muted hover:border-indigo",
              ]}
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
