---
import Layout from "@layouts/Layout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import IndexRow from "@components/IndexRow.astro";
import { getPostRows } from "@utils/posts";

const rows = await getPostRows();
---

<Layout
  title="Writing — Elijah Lewis"
  description="Essays and notes by Elijah Lewis."
>
  <section class="mx-auto w-full max-w-[1100px] px-6 py-14 md:px-10">
    <SectionHeader
      as="h1"
      title="Writing"
      caption={`[ ${rows.length} essays ]`}
    />
    {rows.map((r) => <IndexRow {...r} />)}
  </section>
</Layout>
